TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Opção 1: Login automático (recomendado para GitHub Actions)
# IMPORTANTE: Use uma conta AUXILIAR do LinkedIn, nunca a conta pessoal!
LI_EMAIL=conta_auxiliar@gmail.com
LI_PASSWORD=senha_da_conta_auxiliar

# Opção 2: Cookie manual (para uso local pontual)
# Pegar em: F12 → Application → Cookies → linkedin.com → li_at
# LI_AT_COOKIE=seu_cookie_aqui

# Claude API — necessário para o comando /ask no Telegram
# Gere em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua_chave_anthropic
